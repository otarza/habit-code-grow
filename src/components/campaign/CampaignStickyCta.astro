---
interface Props {
  eyebrow: string;
  label: string;
  price: string;
  /** Product slug — wires the button click to the global flitt:open handler. */
  product: 'bootcamp' | 'pro';
}

const { eyebrow, label, price, product } = Astro.props;
---

<div class="campaign-sticky-cta" aria-label={label}>
  <div>
    <span>{eyebrow}</span>
    <strong>{price}</strong>
  </div>
  <button type="button" data-buy={product}>
    <span>{label}</span>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M5 12h14"></path>
      <path d="m12 5 7 7-7 7"></path>
    </svg>
  </button>
</div>
