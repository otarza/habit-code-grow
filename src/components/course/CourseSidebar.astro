---
import { loadManifest, type Collection } from '@/lib/course-manifest';

interface Props {
  collection: Collection;
  courseSlug: string;
  currentTopicSlug?: string;
  currentLessonSlug?: string;
  routeBasePath: string;
}

const { collection, courseSlug, currentTopicSlug, currentLessonSlug, routeBasePath } =
  Astro.props;
const manifest = loadManifest(collection, courseSlug);
const lessonCount = manifest
  ? manifest.topics.reduce((acc, t) => acc + t.lessons.length, 0)
  : 0;
---

{manifest && (
  <aside class="course-sidebar">
    <a href={routeBasePath} class="course-sidebar__header">
      <h2>{manifest.title}</h2>
      <p>{manifest.topics.length} თავი · {lessonCount} გაკვეთილი</p>
    </a>

    <nav class="course-sidebar__nav" aria-label="კურსის ნავიგაცია">
      {manifest.topics.map((topic) => {
        const isCurrentTopic = topic.slug === currentTopicSlug;
        return (
          <details open={isCurrentTopic} class="course-sidebar__topic">
            <summary>
              <span class="course-sidebar__chev" aria-hidden="true">▸</span>
              {topic.title}
            </summary>
            <ul>
              {topic.lessons.map((lesson) => {
                const active = isCurrentTopic && lesson.slug === currentLessonSlug;
                return (
                  <li>
                    <a
                      href={`${routeBasePath}/${topic.slug}/${lesson.slug}`}
                      class:list={['course-sidebar__lesson', { active }]}
                    >
                      <span class="course-sidebar__lesson-icon" aria-hidden="true">
                        {lesson.videoUrl ? '▶' : '📖'}
                      </span>
                      <span class="course-sidebar__lesson-title">{lesson.title}</span>
                    </a>
                  </li>
                );
              })}
            </ul>
          </details>
        );
      })}
    </nav>
  </aside>
)}

<style>
  .course-sidebar {
    position: sticky;
    top: 0;
    align-self: start;
    height: 100vh;
    overflow-y: auto;
    border-right: 1px solid var(--cp-border, hsl(220 13% 91%));
    background: var(--cp-bg, hsl(0 0% 100%));
    padding: 1rem;
    font-size: 0.875rem;
  }
  .course-sidebar__header {
    display: block;
    text-decoration: none;
    color: inherit;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--cp-border, hsl(220 13% 91%));
    margin-bottom: 1rem;
  }
  .course-sidebar__header h2 {
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.3;
    color: var(--cp-text-primary, hsl(220 47% 15%));
    margin: 0 0 0.25rem;
  }
  .course-sidebar__header p {
    font-size: 0.75rem;
    color: var(--cp-text-muted, hsl(220 9% 46%));
    margin: 0;
  }
  .course-sidebar__topic {
    margin-bottom: 0.5rem;
  }
  .course-sidebar__topic > summary {
    cursor: pointer;
    list-style: none;
    padding: 0.5rem 0.75rem;
    font-weight: 600;
    color: var(--cp-text-primary, hsl(220 47% 15%));
    border-radius: 0.375rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .course-sidebar__topic > summary::-webkit-details-marker {
    display: none;
  }
  .course-sidebar__topic > summary:hover {
    background: hsl(220 13% 95%);
  }
  .course-sidebar__chev {
    display: inline-block;
    transition: transform 0.15s;
    font-size: 0.75rem;
    color: var(--cp-text-muted, hsl(220 9% 46%));
  }
  .course-sidebar__topic[open] > summary > .course-sidebar__chev {
    transform: rotate(90deg);
  }
  .course-sidebar__topic ul {
    list-style: none;
    padding: 0;
    margin: 0.25rem 0 0 1rem;
    border-left: 1px solid var(--cp-border, hsl(220 13% 91%));
  }
  .course-sidebar__lesson {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 0.375rem 0.75rem;
    text-decoration: none;
    color: var(--cp-text-secondary, hsl(220 15% 35%));
    border-radius: 0.25rem;
    font-size: 0.8125rem;
    line-height: 1.4;
  }
  .course-sidebar__lesson:hover {
    background: hsl(220 13% 95%);
    color: var(--cp-text-primary, hsl(220 47% 15%));
  }
  .course-sidebar__lesson.active {
    background: var(--cp-accent-text, hsl(258 90% 56%));
    color: white;
    font-weight: 500;
  }
  .course-sidebar__lesson-icon {
    flex-shrink: 0;
    font-size: 0.75rem;
    margin-top: 0.125rem;
  }
  .course-sidebar__lesson-title {
    min-width: 0;
    word-break: break-word;
  }

  @media (max-width: 1023px) {
    .course-sidebar {
      position: static;
      height: auto;
      max-height: 16rem;
      border-right: 0;
      border-bottom: 1px solid var(--cp-border, hsl(220 13% 91%));
    }
  }
</style>
