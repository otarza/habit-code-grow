---
// Lead-with-free section: 7 free course cards + premium training card +
// BitCamp community CTA + final scroll-to-pricing CTA.
//
// Phase 1: course cards link to the existing Tally hosted form
// (`/r/wQ6DPk`) for email capture, mirroring production. Phase 3 may
// link individual cards directly to /courses/{slug} once the content
// collection is in place.
//
// Skipped from production: animated gradient particles on the premium
// card (decorative). Phase 2 polish can revisit.

const FREE_COURSES_FORM = 'https://tally.so/r/wQ6DPk';

const courses = [
  { title: 'Python პროგრამირება', icon: '🐍', description: 'დაიწყე პროგრამირების სწავლა Python-ით', color: 'bg-secondary' },
  { title: 'SQL მონაცემთა ბაზები', icon: '🗄️', description: 'ისწავლე მონაცემთა ბაზების საფუძვლები', color: 'bg-accent' },
  { title: 'HTML/CSS & JavaScript', icon: '🌐', description: 'ისწავლე ვებ-გვერდების შექმნის საფუძვლები', color: 'bg-blue-500' },
  { title: 'კომპიუტერული მეცნიერება', icon: '💻', description: 'გაეცანი CS-ის ფუნდამენტურ ცნებებს', color: 'bg-purple-500' },
  { title: 'React', icon: '⚛️', description: 'ისწავლე React ბიბლიოთეკა UI შესაქმნელად', color: 'bg-cyan-500' },
  { title: 'Java პროგრამირება', icon: '♨️', description: 'შეისწავლე Java პროგრამირების ენა', color: 'bg-orange-500' },
  { title: 'Angular', icon: '🅰️', description: 'ისწავლე თანამედროვე Front-End აპლიკაციების შექმნა Angular - ით', color: 'bg-red-500' },
];
---

<section id="free-courses" class="py-20 bg-gradient-to-b from-background to-surface overflow-hidden">
  <div class="w-full max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
    {/* Header */}
    <div class="text-center mb-12 px-2 sm:px-0">
      <div class="inline-flex items-center gap-2 bg-green-100 text-green-700 px-3 sm:px-4 py-2 rounded-full text-xs sm:text-sm font-semibold mb-6 max-w-full">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0" aria-hidden="true">
          <path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"></path>
        </svg>
        <span class="whitespace-nowrap">დაიწყე რისკის გარეშე - 100% უფასოდ</span>
      </div>
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-text-primary mb-4 flex items-center justify-center gap-3 flex-wrap">
        <span>BitCamp - ის უფასო კურსები პროგრამირებაში</span>
        <span class="text-3xl" aria-hidden="true">🎁</span>
      </h2>
      <p class="text-base sm:text-lg text-text-secondary max-w-2xl mx-auto px-2 sm:px-0">
        გაეცანი ჩვენს სასწავლო მეთოდს და მიიღე ღირებული ცოდნა სრულიად უფასოდ. ამ კურსებით
        50K+ ადამიანმა დაიწყო გზა ტექნოლოგიურ კარიერაში.
      </p>
    </div>

    {/* Course grid */}
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 max-w-6xl mx-auto mb-12">
      {courses.map((course) => (
        <article class="relative p-4 sm:p-6 bg-card text-card-foreground rounded-lg border border-border shadow-soft hover:shadow-medium transition-shadow duration-300 h-full flex flex-col">
          <div class="absolute top-3 right-3 bg-green-500 text-white px-3 py-1 rounded-full text-xs font-bold shadow-md">
            უფასო
          </div>
          <div class:list={[course.color, 'w-16 h-16 rounded-xl flex items-center justify-center mb-4 text-2xl']}>
            {course.icon}
          </div>
          <h3 class="text-xl font-bold text-text-primary mb-2 break-words normal-case" style="font-feature-settings: normal;">
            {course.title}
          </h3>
          <p class="text-text-secondary mb-4 flex-grow">{course.description}</p>
          <a
            href={FREE_COURSES_FORM}
            target="_blank"
            rel="noopener noreferrer"
            class="w-full mt-auto inline-flex items-center justify-center gap-2 px-4 py-2 border border-primary text-primary hover:bg-primary hover:text-primary-foreground rounded-md text-sm font-semibold transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
              <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
            </svg>
            დაიწყე სწავლა
          </a>
        </article>
      ))}

      {/* Premium training card */}
      <a
        href="#pricing"
        class="relative p-4 sm:p-6 rounded-lg overflow-hidden h-full flex flex-col group cursor-pointer hover:scale-[1.02] transition-transform duration-300"
      >
        <div class="absolute top-3 right-3 z-20 bg-yellow-400 text-yellow-900 px-3 py-1 rounded-full text-xs font-bold shadow-lg animate-pulse">
          ფასიანი
        </div>
        <div class="absolute inset-0 bg-gradient-to-br from-secondary via-primary to-accent opacity-90"></div>
        <div class="relative z-10 flex flex-col h-full">
          <div class="w-16 h-16 bg-white/20 backdrop-blur-sm rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white animate-pulse" aria-hidden="true">
              <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2 break-words normal-case" style="font-feature-settings: normal;">
            პირადი სამენტორო <span aria-hidden="true">🚀</span>
          </h3>
          <p class="text-white/90 mb-4 flex-grow">
            მიიღე პერსონალური მხარდაჭერა და ისწავლე გაცილებით ეფექტურად
          </p>
          <span class="w-full mt-auto inline-flex items-center justify-center gap-2 px-4 py-2 bg-white text-primary hover:bg-white/90 rounded-md text-sm font-bold transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
            </svg>
            კონსულტაცია
          </span>
        </div>
      </a>
    </div>

    {/* Community card */}
    <div class="p-4 sm:p-8 bg-gradient-to-r from-primary/5 to-secondary/5 border-2 border-primary/20 rounded-lg max-w-3xl mx-auto">
      <div class="flex flex-col sm:flex-row items-start gap-4">
        <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary" aria-hidden="true">
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
            <circle cx="9" cy="7" r="4"></circle>
            <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
          </svg>
        </div>
        <div class="flex-1">
          <h3 class="text-xl font-bold text-text-primary mb-2 normal-case" style="font-feature-settings: normal;">
            შემოუერთდი BitCamp საზოგადოებას
          </h3>
          <p class="text-text-secondary mb-4">
            უფასო კურსების დაწყებით ავტომატურად ხდები BitCamp - ის საზოგადოების წევრი. მიიღე
            წვდომა Discord სერვერზე, სადაც შეგიძლია დახმარება სთხოვო საზოგადოების სხვა
            წევრებს.
          </p>
          <div class="flex items-center gap-2 text-sm text-text-muted mb-4">
            <div class="w-2 h-2 bg-green-500 rounded-full"></div>
            <span>55k აქტიური წევრი Facebook ჯგუფში</span>
          </div>
          <div class="flex flex-col sm:flex-row gap-3">
            <a
              href="https://www.facebook.com/groups/bitcamp.ge"
              target="_blank"
              rel="noopener noreferrer"
              class="flex-1 inline-flex items-center justify-center gap-2 px-4 py-2 bg-[#1877F2] hover:bg-[#166FE5] text-white rounded-md text-sm font-semibold transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M9.198 21.5h4v-8.01h3.604l.396-3.98h-4V7.5a1 1 0 0 1 1-1h3v-4h-3a5 5 0 0 0-5 5v2.01h-2l-.396 3.98h2.396z"></path>
              </svg>
              Facebook ჯგუფი
            </a>
            <a
              href="https://discord.gg/AGAW3xmGPr"
              target="_blank"
              rel="noopener noreferrer"
              class="flex-1 inline-flex items-center justify-center gap-2 px-4 py-2 bg-[#5865F2] hover:bg-[#4752C4] text-white rounded-md text-sm font-semibold transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
              </svg>
              Discord სერვერი
            </a>
          </div>
        </div>
      </div>
    </div>

    {/* Final CTA card */}
    <div class="text-center mt-12 bg-gradient-to-r from-primary/5 to-secondary/5 border-2 border-primary/20 rounded-2xl p-4 sm:p-8 max-w-3xl mx-auto">
      <h3 class="text-lg sm:text-xl md:text-2xl font-bold text-text-primary mb-3 normal-case" style="font-feature-settings: normal;">
        მოგეწონა ჩვენი უფასო კურსები?
      </h3>
      <p class="text-sm sm:text-base text-text-secondary mb-6">
        შემოგვიერთდი ჩვენს სამენტორო პროგრამაზე სადაც ვიზრუნებთ შენს სწრაფ ზრდასა და
        განვითარებაზე.
      </p>
      <a
        href="#pricing"
        class="group inline-flex items-center justify-center gap-2 w-full sm:w-auto px-6 py-3 bg-secondary text-secondary-foreground hover:bg-secondary-hover rounded-md text-sm sm:text-base font-bold transition-colors"
      >
        <span>იხილე სამენტორო პროგრამები</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform flex-shrink-0" aria-hidden="true">
          <polyline points="16 18 22 12 16 6"></polyline>
          <polyline points="8 6 2 12 8 18"></polyline>
        </svg>
      </a>
    </div>
  </div>
</section>
