<script>
  import { handleBuy } from '@/lib/checkout';

  // Wire all [data-buy] buttons on this page to handleBuy. handleBuy fires GA/Meta
  // tracking + dispatches the `flitt:open` CustomEvent the modal listens for.
  document.querySelectorAll<HTMLElement>('[data-buy]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const product = btn.getAttribute('data-buy');
      if (product === 'bootcamp' || product === 'pro') {
        handleBuy(product);
      }
    });
  });
</script>
