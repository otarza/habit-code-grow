---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<!--
  Phase 1 placeholder homepage. Validates that Navbar.astro + Footer.astro
  build and render correctly. Phase 2 replaces the <main> content with the
  real homepage composition (Hero, FreeCourses, Pricing, etc.).
-->
<BaseLayout
  title="BitCamp — სწავლა და ბრძოლა"
  description="ისწავლე AI, Python, SQL პროგრამირება BitCamp-ში — უფასო კურსები, ჩელენჯები და მენტორობა."
>
  <Navbar />

  <main class="min-h-[60vh] flex items-center justify-center px-4 py-24 text-center">
    <div class="max-w-xl">
      <p class="text-sm font-semibold text-text-muted uppercase tracking-widest mb-4">
        ვებგვერდი ახლდება
      </p>
      <h1 class="text-3xl sm:text-4xl font-bold text-text-primary mb-4 normal-case">
        მალე ვბრუნდებით
      </h1>
      <p class="text-text-secondary leading-relaxed mb-8">
        BitCamp-ის ვებგვერდი იშენება ხელახლა. სანამ პროცესი დასრულდება, შეგიძლია
        ნახო მომსახურების პირობები ან მოგვწერო პირდაპირ.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/terms"
          class="inline-flex items-center justify-center px-4 py-2 text-sm font-medium border border-primary text-primary rounded-md hover:bg-primary hover:text-primary-foreground transition-colors"
        >
          მომსახურების პირობები
        </a>
        <a
          href="mailto:hello@bitcamp.ge"
          class="inline-flex items-center justify-center px-4 py-2 text-sm font-medium text-text-secondary hover:text-text-primary transition-colors"
        >
          hello@bitcamp.ge →
        </a>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
