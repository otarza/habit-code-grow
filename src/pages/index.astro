---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import FreeCoursesSection from '../components/FreeCoursesSection.astro';
import PricingSection from '../components/PricingSection.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
---

<!--
  Phase 1 interim homepage. Composes the chrome + 4 ported sections.
  Phase 2 inserts the remaining sections in their production order between
  Hero and FAQ: VideoExplainer, Testimonials, ProblemSolution, ThreeStepPlan,
  HowItWorks, SuccessFailureContrast, ChallengeTransformation, StickyCtaBar.
-->
<BaseLayout
  title="BitCamp — სწავლა და ბრძოლა"
  description="ისწავლე AI, Python, SQL პროგრამირება BitCamp-ში — უფასო კურსები, ჩელენჯები და მენტორობა."
>
  <Navbar />
  <FreeCoursesSection />
  <Hero />
  <PricingSection />
  <FAQ />
  <Footer />
</BaseLayout>
