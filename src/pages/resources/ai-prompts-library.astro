---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import bitcampLogo from '@/assets/bitcamp-logo.png';
import { AI_PROMPTS, PROMPT_CATEGORIES } from '@/data/aiPrompts';

const totalPrompts = AI_PROMPTS.length;
const categoryCounts = Object.fromEntries(
  PROMPT_CATEGORIES.map((c) => [c.id, AI_PROMPTS.filter((p) => p.category === c.id).length]),
);
const categoryMap = Object.fromEntries(PROMPT_CATEGORIES.map((c) => [c.id, c]));

// Build per-card search haystack at build time (title + description + tags + both prompt bodies, lowercased).
function buildSearchText(p: (typeof AI_PROMPTS)[number]): string {
  return [p.title, p.description, p.tags.join(' '), p.prompt.ka, p.prompt.en]
    .join(' ')
    .toLowerCase();
}
---

<BaseLayout
  title={`AI პრომპტების ბიბლიოთეკა — ${totalPrompts}+ მზა პრომპტი | BitCamp`}
  description={`${totalPrompts} მზა, ტესტირებული AI პრომპტი ChatGPT-სთვის, Claude-სა და Gemini-სთვის — კოდი, წერა, ბიზნესი, კარიერა, სწავლა. დააკოპირე და გამოიყენე უფასოდ.`}
  canonical="https://www.bitcamp.ge/resources/ai-prompts-library"
  bodyClass="dark"
>
  <div
    class="min-h-screen bg-background text-foreground"
    data-lang="ka"
    data-prompt-root
  >
    {/* Top bar */}
    <header class="border-b border-white/10">
      <div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8 flex h-16 items-center justify-between">
        <a href="/" aria-label="BitCamp — მთავარი" class="flex items-center gap-2">
          <Image src={bitcampLogo} alt="BitCamp" height={28} class="h-7 w-auto invert" />
        </a>
        <a
          href="/ai-bootcamp"
          class="inline-flex items-center gap-1.5 text-sm font-medium text-white/70 transition-colors hover:text-white"
        >
          AI კურსი
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
          </svg>
        </a>
      </div>
    </header>

    {/* Hero */}
    <section class="relative overflow-hidden">
      <div
        class="pointer-events-none absolute inset-x-0 top-0 h-[420px]"
        style="background: radial-gradient(60% 60% at 50% 0%, rgba(244,63,94,0.14), transparent 72%);"
        aria-hidden="true"
      ></div>
      <div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8 relative pb-10 pt-14 text-center">
        <span class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] px-3.5 py-1.5 text-xs font-medium text-white/70">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-rose-300" aria-hidden="true">
            <path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"></path>
          </svg>
          უფასო რესურსი BitCamp-ისგან
        </span>
        <h1 class="mx-auto mt-5 max-w-3xl text-3xl font-bold leading-tight text-white sm:text-4xl lg:text-5xl">
          AI პრომპტების ბიბლიოთეკა
        </h1>
        <p class="mx-auto mt-4 max-w-2xl text-base leading-7 text-white/60 sm:text-lg">
          {totalPrompts} მზა, ტესტირებული პრომპტი ChatGPT-სთვის, Claude-სა და Gemini-სთვის.
          აირჩიე, დააკოპირე და გამოიყენე — დღესვე.
        </p>
        <div class="mt-6 flex flex-wrap items-center justify-center gap-x-3 gap-y-1.5 text-sm text-white/45">
          <span>{totalPrompts} პრომპტი</span>
          <span aria-hidden="true">·</span>
          <span>{PROMPT_CATEGORIES.length} კატეგორია</span>
          <span aria-hidden="true">·</span>
          <span>ქართული და English</span>
        </div>
      </div>
    </section>

    {/* Sticky controls */}
    <div class="sticky top-0 z-30 border-y border-white/10 bg-background/95 backdrop-blur-md">
      <div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8 space-y-3 py-4">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
          <div class="relative flex-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="pointer-events-none absolute left-3.5 top-1/2 -translate-y-1/2 text-white/35" aria-hidden="true">
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.3-4.3"></path>
            </svg>
            <input
              type="text"
              inputmode="search"
              placeholder="მოძებნე პრომპტი — მაგ. „კოდი“, „ელ. ფოსტა“, „SQL“…"
              aria-label="პრომპტების ძიება"
              class="w-full rounded-xl border border-white/10 bg-white/[0.04] py-3 pl-10 pr-10 text-sm text-white outline-none transition-colors placeholder:text-white/35 focus:border-white/30"
              data-prompt-search
            />
            <button
              type="button"
              class="absolute right-2.5 top-1/2 hidden h-7 w-7 -translate-y-1/2 items-center justify-center rounded-md text-white/45 transition-colors hover:bg-white/10 hover:text-white"
              aria-label="ძიების გასუფთავება"
              data-prompt-search-clear
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M18 6 6 18"></path><path d="m6 6 12 12"></path>
              </svg>
            </button>
          </div>

          <div class="flex flex-shrink-0 items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white/35" aria-hidden="true">
              <path d="m5 8 6 6"></path><path d="m4 14 6-6 2-3"></path><path d="M2 5h12"></path><path d="M7 2h1"></path><path d="m22 22-5-10-5 10"></path><path d="M14 18h6"></path>
            </svg>
            <div class="inline-flex rounded-lg border border-white/10 bg-white/[0.04] p-1" role="group" aria-label="ენის გადართვა">
              <button
                type="button"
                class="rounded-md px-3 py-1.5 text-sm font-medium transition-colors bg-white text-slate-950"
                aria-pressed="true"
                data-prompt-lang="ka"
              >ქართული</button>
              <button
                type="button"
                class="rounded-md px-3 py-1.5 text-sm font-medium transition-colors text-white/55 hover:text-white"
                aria-pressed="false"
                data-prompt-lang="en"
              >English</button>
            </div>
          </div>
        </div>

        <div class="flex gap-2 overflow-x-auto pb-0.5" role="group" aria-label="კატეგორიის ფილტრი">
          <button
            type="button"
            class="inline-flex flex-none items-center gap-1.5 rounded-full border px-3.5 py-1.5 text-sm font-medium transition-colors border-white bg-white text-slate-950"
            aria-pressed="true"
            data-prompt-cat="all"
          >
            ყველა
            <span class="text-slate-500">{totalPrompts}</span>
          </button>
          {PROMPT_CATEGORIES.map((c) => (
            <button
              type="button"
              class="inline-flex flex-none items-center gap-1.5 rounded-full border px-3.5 py-1.5 text-sm font-medium transition-colors border-white/10 bg-white/[0.04] text-white/60 hover:border-white/25 hover:text-white"
              aria-pressed="false"
              data-prompt-cat={c.id}
            >
              <span aria-hidden="true">{c.emoji}</span>
              {c.label}
              <span class="text-white/35">{categoryCounts[c.id]}</span>
            </button>
          ))}
        </div>
      </div>
    </div>

    {/* Results */}
    <section class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
      <p class="mb-5 text-sm text-white/40">
        ნაჩვენებია <span class="font-medium text-white/70" data-prompt-count>{totalPrompts}</span> პრომპტი
      </p>

      <div
        class="hidden rounded-2xl border border-white/10 bg-white/[0.03] py-16 text-center"
        data-prompt-empty
      >
        <p class="font-medium text-white/75">ვერაფერი მოიძებნა</p>
        <p class="mt-1 text-sm text-white/45">სცადე სხვა საძიებო სიტყვა ან აირჩიე სხვა კატეგორია.</p>
      </div>

      <div class="grid gap-5 lg:grid-cols-2" data-prompt-grid>
        {AI_PROMPTS.map((p) => {
          const cat = categoryMap[p.category];
          return (
            <article
              class="flex flex-col rounded-2xl border border-white/10 bg-white/[0.03] p-5 transition-colors hover:border-white/20"
              data-prompt-card
              data-category={p.category}
              data-search={buildSearchText(p)}
            >
              <div class="mb-3">
                <span class:list={['inline-flex items-center gap-1.5 rounded-full border px-2.5 py-1 text-xs font-medium', cat.badgeClass]}>
                  <span aria-hidden="true">{cat.emoji}</span>
                  {cat.label}
                </span>
              </div>
              <h3 class="text-[17px] font-bold normal-case leading-snug text-white" style="font-feature-settings: normal;">
                {p.title}
              </h3>
              <p class="mt-1.5 text-sm leading-6 text-white/55">{p.description}</p>

              <pre
                class="prompt-body prompt-body--ka mt-4 max-h-72 overflow-y-auto whitespace-pre-wrap rounded-xl border border-white/10 bg-black/40 p-3.5 text-[13px] leading-6 text-white/80 font-body"
                data-prompt-text="ka"
              >{p.prompt.ka}</pre>
              <pre
                class="prompt-body prompt-body--en mt-4 max-h-72 overflow-y-auto whitespace-pre-wrap rounded-xl border border-white/10 bg-black/40 p-3.5 text-[13px] leading-6 text-white/80 font-mono"
                data-prompt-text="en"
              >{p.prompt.en}</pre>

              <div class="mt-auto flex items-center justify-between gap-3 pt-4">
                <div class="flex min-w-0 flex-wrap gap-1.5">
                  {p.tags.slice(0, 3).map((tag) => (
                    <span class="rounded-md bg-white/[0.06] px-2 py-0.5 text-[11px] text-white/40">#{tag}</span>
                  ))}
                </div>
                <button
                  type="button"
                  class="inline-flex flex-shrink-0 items-center gap-1.5 rounded-lg px-3.5 py-2 text-sm font-semibold transition-colors bg-white text-slate-950 hover:bg-white/90"
                  aria-label={`„${p.title}“ პრომპტის კოპირება`}
                  data-prompt-copy
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="prompt-copy-icon" aria-hidden="true">
                    <rect width="14" height="14" x="8" y="8" rx="2" ry="2"></rect>
                    <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"></path>
                  </svg>
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="prompt-check-icon hidden" aria-hidden="true">
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                  <span class="prompt-copy-label">კოპირება</span>
                </button>
              </div>
            </article>
          );
        })}
      </div>
    </section>

    {/* Conversion banner */}
    <section class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8 pb-16">
      <div class="relative overflow-hidden rounded-3xl border border-white/10 p-8 text-center sm:p-12" style="background: linear-gradient(135deg, rgba(244,63,94,0.13), rgba(255,255,255,0.02), rgba(56,189,248,0.1));">
        <h2 class="mx-auto max-w-2xl text-2xl font-bold leading-tight text-white sm:text-3xl">
          გინდა AI პროფესიონალურად ისწავლო?
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-base leading-7 text-white/65">
          ეს ბიბლიოთეკა მხოლოდ დასაწყისია. BitCamp-ის AI კურსზე ისწავლი, როგორ ააწყო შენი
          პრომპტები ნულიდან, ჩართო AI ყოველდღიურ საქმეში და რამდენჯერმე დააჩქარო შენი
          მუშაობა.
        </p>
        <div class="mt-7 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a
            href="/ai-bootcamp"
            class="inline-flex w-full items-center justify-center gap-2 rounded-xl bg-white px-6 py-3 text-sm font-bold text-slate-950 transition-colors hover:bg-white/90 sm:w-auto"
          >
            გაიცანი AI Bootcamp
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
            </svg>
          </a>
          <a
            href="/ai"
            class="inline-flex w-full items-center justify-center gap-2 rounded-xl border border-white/15 bg-white/[0.04] px-6 py-3 text-sm font-semibold text-white/85 transition-colors hover:border-white/30 hover:text-white sm:w-auto"
          >
            მენტორობით სწავლა
          </a>
        </div>
      </div>
    </section>

    {/* Footer */}
    <footer class="border-t border-white/10">
      <div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8 flex flex-col items-center justify-between gap-4 py-8 sm:flex-row">
        <div class="flex items-center gap-3">
          <Image src={bitcampLogo} alt="BitCamp" height={24} class="h-6 w-auto invert" />
          <span class="text-sm text-white/40">© {new Date().getFullYear()} BitCamp</span>
        </div>
        <nav class="flex items-center gap-5 text-sm text-white/55">
          <a href="/" class="transition-colors hover:text-white">მთავარი</a>
          <a href="/ai-bootcamp" class="transition-colors hover:text-white">AI კურსი</a>
          <a href="/terms" class="transition-colors hover:text-white">წესები</a>
        </nav>
      </div>
    </footer>
  </div>
</BaseLayout>

<style is:global>
  [data-prompt-root][data-lang='ka'] [data-prompt-text='en'] { display: none; }
  [data-prompt-root][data-lang='en'] [data-prompt-text='ka'] { display: none; }
</style>

<script>
  const root = document.querySelector<HTMLElement>('[data-prompt-root]');
  if (root) {
    const cards = Array.from(root.querySelectorAll<HTMLElement>('[data-prompt-card]'));
    const searchInput = root.querySelector<HTMLInputElement>('[data-prompt-search]');
    const searchClear = root.querySelector<HTMLButtonElement>('[data-prompt-search-clear]');
    const categoryBtns = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-prompt-cat]'));
    const langBtns = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-prompt-lang]'));
    const copyBtns = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-prompt-copy]'));
    const emptyEl = root.querySelector<HTMLElement>('[data-prompt-empty]');
    const gridEl = root.querySelector<HTMLElement>('[data-prompt-grid]');
    const countEl = root.querySelector<HTMLElement>('[data-prompt-count]');

    let category = 'all';
    let query = '';

    const applyFilters = () => {
      const q = query.trim().toLowerCase();
      let visible = 0;
      for (const card of cards) {
        const cat = card.dataset.category ?? '';
        const hay = card.dataset.search ?? '';
        const okCat = category === 'all' || cat === category;
        const okSearch = !q || hay.includes(q);
        const show = okCat && okSearch;
        card.hidden = !show;
        if (show) visible++;
      }
      if (countEl) countEl.textContent = String(visible);
      if (emptyEl && gridEl) {
        emptyEl.classList.toggle('hidden', visible !== 0);
        gridEl.classList.toggle('hidden', visible === 0);
      }
      if (searchClear) searchClear.classList.toggle('hidden', q.length === 0);
      if (searchClear) searchClear.style.display = q.length === 0 ? 'none' : 'inline-flex';
    };

    searchInput?.addEventListener('input', (e) => {
      query = (e.target as HTMLInputElement).value;
      applyFilters();
    });
    searchClear?.addEventListener('click', () => {
      if (!searchInput) return;
      searchInput.value = '';
      query = '';
      searchInput.focus();
      applyFilters();
    });

    const setCategoryActive = (btn: HTMLButtonElement) => {
      for (const b of categoryBtns) {
        const active = b === btn;
        b.setAttribute('aria-pressed', String(active));
        b.classList.toggle('border-white', active);
        b.classList.toggle('bg-white', active);
        b.classList.toggle('text-slate-950', active);
        b.classList.toggle('border-white/10', !active);
        b.classList.toggle('bg-white/[0.04]', !active);
        b.classList.toggle('text-white/60', !active);
        b.classList.toggle('hover:border-white/25', !active);
        b.classList.toggle('hover:text-white', !active);
        const countSpan = b.querySelector<HTMLElement>('span:last-child');
        if (countSpan) {
          countSpan.classList.toggle('text-slate-500', active);
          countSpan.classList.toggle('text-white/35', !active);
        }
      }
    };
    for (const btn of categoryBtns) {
      btn.addEventListener('click', () => {
        category = btn.dataset.cat ?? 'all';
        setCategoryActive(btn);
        applyFilters();
      });
    }

    const setLangActive = (btn: HTMLButtonElement) => {
      const lang = btn.dataset.lang ?? 'ka';
      root.setAttribute('data-lang', lang);
      for (const b of langBtns) {
        const active = b === btn;
        b.setAttribute('aria-pressed', String(active));
        b.classList.toggle('bg-white', active);
        b.classList.toggle('text-slate-950', active);
        b.classList.toggle('text-white/55', !active);
        b.classList.toggle('hover:text-white', !active);
      }
    };
    for (const btn of langBtns) {
      btn.addEventListener('click', () => setLangActive(btn));
    }

    for (const btn of copyBtns) {
      btn.addEventListener('click', async () => {
        const card = btn.closest('[data-prompt-card]');
        if (!card) return;
        const lang = root.getAttribute('data-lang') ?? 'ka';
        const text = card.querySelector(`[data-prompt-text="${lang}"]`)?.textContent ?? '';
        try {
          await navigator.clipboard.writeText(text);
          const icon = btn.querySelector<HTMLElement>('.prompt-copy-icon');
          const check = btn.querySelector<HTMLElement>('.prompt-check-icon');
          const label = btn.querySelector<HTMLElement>('.prompt-copy-label');
          icon?.classList.add('hidden');
          check?.classList.remove('hidden');
          if (label) label.textContent = 'დაკოპირდა';
          btn.classList.remove('bg-white', 'text-slate-950', 'hover:bg-white/90');
          btn.classList.add('bg-emerald-500/15', 'text-emerald-300');
          setTimeout(() => {
            icon?.classList.remove('hidden');
            check?.classList.add('hidden');
            if (label) label.textContent = 'კოპირება';
            btn.classList.add('bg-white', 'text-slate-950', 'hover:bg-white/90');
            btn.classList.remove('bg-emerald-500/15', 'text-emerald-300');
          }, 2000);
        } catch {
          // navigator.clipboard rejected — silently no-op (user can select manually)
        }
      });
    }

    applyFilters();
  }
</script>
