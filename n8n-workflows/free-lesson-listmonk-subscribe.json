    },
    {
      "parameters": {
        "jsCode": "const body = $json.body || $json;\nconst email = String(body.email || '').trim().toLowerCase();\nconst listId = Number(body.listId);\nconst allowedLists = new Set([4, 5]);\n\nif (!/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(email) || !allowedLists.has(listId)) {\n  throw new Error('Invalid free lesson subscription payload');\n}\n\nconst attribs = {\n  source: String(body.source || ''),\n  path: String(body.path || ''),\n  utm_source: String(body.utmSource || ''),\n  utm_medium: String(body.utmMedium || ''),\n  utm_campaign: String(body.utmCampaign || ''),\n  fbclid: String(body.fbclid || ''),\n  subscribed_from: 'free_lesson_modal'\n};\n\nreturn [{ json: { email, listId, listKey: String(body.listKey || ''), attribs } }];"
      },
      "id": "validate-payload",
      "name": "Validate Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "url": "https://news.bitcamp.ge/api/subscribers",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBasicAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "query",
              "value": "={{ \"subscribers.email = '\" + $json.email.replaceAll(\"'\", \"''\") + \"'\" }}"
            },
            {
              "name": "page",
              "value": "1"
            },
            {
              "name": "per_page",
              "value": "1"
            }
          ]
        },
        "options": {}
      },
      "id": "find-subscriber",
      "name": "Find Existing Subscriber",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [700, 300],
      "credentials": {
        "httpBasicAuth": {
          "id": "YOUR_LISTMONK_BASIC_AUTH_CREDENTIAL_ID",
          "name": "Listmonk Basic Auth"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const original = $('Validate Payload').item.json;\nconst existing = $json.data?.results?.[0] || null;\nconst existingListIds = Array.isArray(existing?.lists)\n  ? existing.lists.map((list) => Number(list.id || list)).filter(Boolean)\n  : [];\nconst mergedListIds = Array.from(new Set([...existingListIds, original.listId]));\n\nreturn [{\n  json: {\n    ...original,\n    subscriberId: existing?.id || null,\n    createPayload: {\n      email: original.email,\n      name: existing?.name || '',\n      status: 'enabled',\n      lists: [original.listId],\n      preconfirm_subscriptions: true,\n      attribs: original.attribs\n    },\n    patchPayload: {\n      status: 'enabled',\n      lists: mergedListIds,\n      preconfirm_subscriptions: true,\n      attribs: original.attribs\n    }\n  }\n}];"
      },
      "id": "build-listmonk-request",
      "name": "Build Listmonk Request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [940, 300]
    },
